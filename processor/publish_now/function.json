{
  "scriptFile": "__init__.py",
  "bindings": [
    {
      "authLevel": "anonymous",
      "type": "httpTrigger",
      "direction": "in",
      "name": "req",
      "methods": ["get", "post"],
      "route": "publish_now"
    },
    {
      "type": "http",
      "direction": "out",
      "name": "$return"
    },
    {
      "name": "event",
      "type": "eventHub",
      "direction": "out",
      "eventHubName": "weather",
      "connection": "EVENTHUB_SEND_CONNECTION"
    }
  ]
}